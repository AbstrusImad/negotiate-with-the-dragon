# ── Secrets / environment ───────────────────────────────────────────────
# NEVER commit real .env files — contracts/.env holds the deployer PRIVATE KEY
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── Dependencies ────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Logs ────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / OS ─────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp

# ── Python (contract tooling) ───────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ── Misc ────────────────────────────────────────────────────────────────
.cache/
coverage/
.claude/

